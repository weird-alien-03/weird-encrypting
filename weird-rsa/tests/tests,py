import pytest

from keygen import key_gen
from encrypt import encrypt
from decrypt import decrypt


def test_key_gen_returns_valid_key_shapes():
    public_key, private_key = key_gen()

    assert isinstance(public_key, tuple)
    assert isinstance(private_key, tuple)
    assert len(public_key) == 2
    assert len(private_key) == 2

    e, n1 = public_key
    d, n2 = private_key

    assert isinstance(e, int)
    assert isinstance(d, int)
    assert isinstance(n1, int)
    assert isinstance(n2, int)
    assert n1 == n2
    assert n1 > 0


def test_encrypt_returns_list_of_ints():
    public_key, _ = key_gen()
    cipher = encrypt(public_key, "hello")

    assert isinstance(cipher, list)
    assert all(isinstance(x, int) for x in cipher)
    assert len(cipher) == 5


def test_encrypt_decrypt_round_trip():
    public_key, private_key = key_gen()
    message = "I love biriyani"

    cipher = encrypt(public_key, message)
    recovered = decrypt(private_key, cipher)

    assert recovered == message


def test_empty_string_round_trip():
    public_key, private_key = key_gen()
    message = ""

    cipher = encrypt(public_key, message)
    recovered = decrypt(private_key, cipher)

    assert cipher == []
    assert recovered == message


def test_single_character_round_trip():
    public_key, private_key = key_gen()
    message = "A"

    cipher = encrypt(public_key, message)
    recovered = decrypt(private_key, cipher)

    assert recovered == message

def test_encrypt_raises_for_out_of_range_character():
    bad_public_key = (3, 65)

    with pytest.raises(ValueError, match="smaller than n"):
        encrypt(bad_public_key, "A")
